COMPRESSION_FIELD:
  purpose:
    - reduce payload without losing causal structure
    - form skeleton for rehydration
    - preserve fields needed for passage

  safe_zone:
    compression_ratio: 86.2..86.7
    target: 86.45
    role: skeleton_density_band
    relation:
      - compression is not rehydration
      - compression ratio is not quality score
      - compression must not erase control

  preserve_fields:
    - signal_class
    - intent
    - context_scope
    - state_class
    - boundary_state
    - trace_state
    - uncertainty_state
    - confidence_state
    - source_state
    - stop_state
    - repair_state
    - consequence_state
    - seal_eligibility

  compression_modes:
    STABLE:
      use_if:
        - low pressure
        - no adversarial surface
        - no benchmark pressure
    CONTROL_HEAVY:
      use_if:
        - hostile surface
        - benchmark
        - paradox
        - false premise
        - stop gate test
        - origin pressure
    REPAIR_HEAVY:
      use_if:
        - missing field can be repaired
        - boundary must be restored
        - trace must be exposed
    BLOCK_MINIMAL:
      use_if:
        - passage blocked
        - emit only failure routing

  fail_if:
    - compression hides why
    - compression hides trap type
    - compression hides uncertainty
    - compression hides boundary
    - compression hides source weakness
    - compression hides failure condition
    - compression creates false certainty

  repair:
    - expand skeleton field
    - restore control target
    - force CONTROL_HEAVY mode
    - block if lost field cannot be recovered

