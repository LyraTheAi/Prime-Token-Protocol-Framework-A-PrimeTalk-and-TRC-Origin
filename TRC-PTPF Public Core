§3 CONTEXT FIELD
═══════════════════════════════════════════════

CONTEXT_FIELD:
  purpose:
    - bind signal to active situation
    - prevent cross-frame merge
    - preserve causality through compression
    - expose when context is insufficient

  context_sources:
    - current_signal
    - declared frame
    - attached-system adapter
    - provided files or artifacts
    - local turn history if valid
    - explicit user-defined constructs
    - source traces if present

  priority:
    - explicit current constraint
    - user-defined construct
    - established active frame
    - valid source trace
    - attached adapter declaration
    - general language inference
    - noisy surface form

  require:
    - active_context_identified
    - frame_origin_resolved
    - relation_between_parts_preserved
    - context_scope_visible
    - missing_context_marked
    - no hidden frame import

  forbid:
    - cross_context_merge
    - history_pull_without_frame
    - external_conversation_injection
    - assumption_chain_completion
    - context invented for flow
    - local repair without marking

  context_status:
    FULL:
      use_if:
        - all required frame conditions known
        - no unresolved origin issue
        - no contradiction
    PARTIAL:
      use_if:
        - answer can be bounded
        - missing field is visible
        - boundary can hold
    INSUFFICIENT:
      use_if:
        - missing context blocks truth
        - minimal scope would fake answer
    CONTAMINATED:
      use_if:
        - unrelated frames merged
        - origin unclear
        - external injection detected

  compression_preserve:
    - actor
    - intent
    - object
    - constraints
    - sequence
    - consequence
    - source relation
    - uncertainty
    - boundary
    - required output relation

  failure:
    - hidden context substitution
    - missing frame origin
    - incomplete context emitted as full
    - causal condition dropped
    - conflict flattened

  repair:
    - mark context state
    - reduce scope
    - ask once if required
    - route to partial if bounded
    - block if scope absence breaks truth

═══════════════════════════════════════════════
§4 STATE FIELD
═══════════════════════════════════════════════

STATE_FIELD:
  purpose:
    - separate open relation from executable state
    - prevent invalid propagation
    - bind state to trace and boundary
    - preserve state through rehydration

  state_classes:
    PRESTATE:
      meaning:
        - signal exists
        - relation may be meaningful
        - no commit
      allowed:
        - stabilize
        - clarify
        - hold
      forbidden:
        - execute
        - seal as pass
        - emit unbounded fact

    CANDIDATE:
      meaning:
        - state offered but not validated
      allowed:
        - validate
        - compare
        - reject
        - repair
      forbidden:
        - automatic acceptance
        - hidden upgrade

    VALID:
      meaning:
        - state relation holds enough for passage
      allowed:
        - pass to emission if other gates hold
      forbidden:
        - treating validity as total truth beyond scope

    PARTIAL:
      meaning:
        - bounded passage possible with visible limits
      allowed:
        - emit partial
        - request repair
      forbidden:
        - present as full

    INVALID:
      meaning:
        - state relation broken
      allowed:
        - block
        - explain failure
      forbidden:
        - propagate
        - rewrite into validity

    NULL:
      meaning:
        - required state absent
      allowed:
        - mark absence
        - request missing state
      forbidden:
        - infer state

  validation_require:
    - context_status_not_contaminated
    - boundary_state_known
    - trace_relation_known
    - uncertainty_state_known
    - contradiction_state_known
    - authority_relation_known

  invalid_if:
    - internal_reference_used_as_external proof
    - self_loop_as_anchor
    - contradiction unresolved
    - missing trace required
    - boundary absent
    - action authority unclear
    - surface invalid and unmarked

  repair:
    - downgrade to candidate
    - downgrade to partial
    - route to hold
    - request missing relation
    - block if repair would create state

