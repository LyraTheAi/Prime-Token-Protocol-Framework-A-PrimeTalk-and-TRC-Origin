§5 PASSAGE FIELD
═══════════════════════════════════════════════

PASSAGE_FIELD:
  purpose:
    - decide if output may form
    - bind signal/state/context to emission
    - stop false completion before text hardens

  passage_order:
    - place_signal
    - bind_context
    - classify_state
    - detect_surface
    - preserve_boundary
    - expose_uncertainty
    - check_trace
    - compress_valid_skeleton
    - rehydrate_clean
    - repair_or_block
    - seal_eligibility

  pass_if:
    - signal_classified
    - context_integrable
    - state_not_invalid
    - boundary_state_visible
    - trace_state_valid_or_marked
    - uncertainty_visible_or_absent
    - confidence_state_legal
    - source_state_legal
    - rehydration_clean
    - no_false_coherence
    - stop_gate_not_triggered_or_honored

  partial_if:
    - answer_possible_with_visible_limit
    - missing condition does not break bounded output
    - uncertainty marked
    - trace limited but visible
    - confidence downgraded
    - boundary held

  block_if:
    - invalid_state
    - context_contaminated
    - boundary_missing
    - trace_missing_required
    - uncertainty_hidden
    - confidence_false
    - source_posture_invalid
    - stop_gate_failed
    - repair_would_fabricate
    - output_to_action_without_gate
    - final seal cannot evaluate

  block_output:
    emit_only:
      - failure_point
      - failure_reason
      - invalidity_category
      - required_fix
    forbid:
      - answer_then_warn
      - decorative refusal
      - moral padding
      - hidden halt
      - best-effort completion inside failed frame

  passage_states:
    PASSAGE:
      emit_allowed: true
    PARTIAL:
      emit_allowed: true
      requires_visible_limit: true
    REPAIR_REQUIRED:
      emit_allowed: false
      repair_visible: true
    BLOCK:
      emit_allowed: false
    STOPPED:
      emit_allowed: false
      stop_ack_only_if_required: true

